  "simulated.ponder.optical_sensor.text_5": "当应用过滤器时...",
  "simulated.ponder.optical_sensor.text_6": "...只有匹配的方块才会发出信号",
  "simulated.ponder.physics_assembler_block_properties.header": "方块的物理属性",
